{
  "info": {
    "name": "PoloDeck API",
    "description": "PoloDeck water polo scoreboard API. Use collection variables: baseUrl (default http://localhost:3000), gameDayId, gameId, exclusionId, playerId. After creating a game day, set gameDayId; after creating a game, set gameId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "gameDayId", "value": "" },
    { "key": "gameId", "value": "" },
    { "key": "exclusionId", "value": "" },
    { "key": "playerId", "value": "" }
  ],
  "item": [
    {
      "name": "Game Days",
      "item": [
        {
          "name": "Create Game Day",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-03-15\",\n  \"location\": \"Main Pool\",\n  \"defaultQuarterDurationMs\": 480000,\n  \"defaultBreakBetweenQuartersMs\": 30000,\n  \"defaultHalftimeDurationMs\": 180000\n}"
            },
            "url": "{{baseUrl}}/api/game-days"
          }
        },
        {
          "name": "List Game Days",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/game-days"
          }
        },
        {
          "name": "Get Game Day by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/game-days/{{gameDayId}}"
          }
        },
        {
          "name": "Update Game Day",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-03-15\",\n  \"location\": \"Main Pool\",\n  \"defaultQuarterDurationMs\": 480000,\n  \"defaultBreakBetweenQuartersMs\": 30000,\n  \"defaultHalftimeDurationMs\": 180000\n}"
            },
            "url": "{{baseUrl}}/api/game-days/{{gameDayId}}"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Games",
      "item": [
        {
          "name": "Create Game",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameDayId\": \"{{gameDayId}}\",\n  \"homeTeamName\": \"Home Team\",\n  \"awayTeamName\": \"Away Team\",\n  \"level\": \"Varsity\",\n  \"gender\": \"Boys\",\n  \"gameType\": \"League\",\n  \"label\": \"Game 1\",\n  \"totalPeriods\": 4,\n  \"gameClockDurationMs\": 480000,\n  \"shotClockDurationMs\": 30000\n}"
            },
            "url": "{{baseUrl}}/api/games"
          }
        },
        {
          "name": "Update Game",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"homeTeamName\": \"Home Team\",\n  \"awayTeamName\": \"Away Team\",\n  \"level\": \"Varsity\",\n  \"gender\": \"Girls\",\n  \"gameType\": \"Scrimmage\",\n  \"label\": \"Girls Varsity 7pm\"\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}"
          }
        },
        {
          "name": "List Games",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/games"
          }
        },
        {
          "name": "Get Game by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}"
          }
        }
      ]
    },
    {
      "name": "Devices & Capabilities",
      "item": [
        {
          "name": "Device Check-in",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"sb-001\",\n  \"type\": \"SCOREBOARD\",\n  \"name\": \"Main scoreboard\"\n}"
            },
            "url": "{{baseUrl}}/api/devices/check-in"
          }
        },
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/devices"
          }
        },
        {
          "name": "Get Capabilities",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/capabilities"
          }
        }
      ]
    },
    {
      "name": "Score",
      "item": [
        {
          "name": "Home Increment",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/score/home/increment"
          }
        },
        {
          "name": "Home Decrement",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/score/home/decrement"
          }
        },
        {
          "name": "Away Increment",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/score/away/increment"
          }
        },
        {
          "name": "Away Decrement",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/score/away/decrement"
          }
        }
      ]
    },
    {
      "name": "Game Clock",
      "item": [
        {
          "name": "Start",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/game-clock/start"
          }
        },
        {
          "name": "Stop",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/game-clock/stop"
          }
        },
        {
          "name": "Set",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remainingMs\": 120000\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}/game-clock/set"
          }
        }
      ]
    },
    {
      "name": "Shot Clock",
      "item": [
        {
          "name": "Start",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/shot-clock/start"
          }
        },
        {
          "name": "Stop",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/shot-clock/stop"
          }
        },
        {
          "name": "Reset",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/shot-clock/reset"
          }
        },
        {
          "name": "Set",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remainingMs\": 30000\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}/shot-clock/set"
          }
        }
      ]
    },
    {
      "name": "Period",
      "item": [
        {
          "name": "Advance Period",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/period/advance"
          }
        }
      ]
    },
    {
      "name": "Roster",
      "item": [
        {
          "name": "Add Home Player",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capNumber\": \"7\",\n  \"playerName\": \"Player Name\"\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}/roster/home/player"
          }
        },
        {
          "name": "Add Away Player",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capNumber\": \"7\",\n  \"playerName\": \"Player Name\"\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}/roster/away/player"
          }
        },
        {
          "name": "Get Roster",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/roster"
          }
        }
      ]
    },
    {
      "name": "Exclusions",
      "item": [
        {
          "name": "Create Exclusion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerId\": \"{{playerId}}\",\n  \"durationMs\": 20000\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}/exclusions"
          }
        },
        {
          "name": "Get Active Exclusions",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/exclusions/active"
          }
        },
        {
          "name": "Clear Exclusion",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/exclusions/{{exclusionId}}/clear"
          }
        }
      ]
    },
    {
      "name": "Timeouts",
      "item": [
        {
          "name": "Home Full Timeout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/timeouts/home/full"
          }
        },
        {
          "name": "Home Short Timeout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/timeouts/home/short"
          }
        },
        {
          "name": "Away Full Timeout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/timeouts/away/full"
          }
        },
        {
          "name": "Away Short Timeout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/timeouts/away/short"
          }
        },
        {
          "name": "Get Timeouts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/games/{{gameId}}/timeouts"
          }
        }
      ]
    },
    {
      "name": "Horn",
      "item": [
        {
          "name": "Trigger Horn",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"manual\"\n}"
            },
            "url": "{{baseUrl}}/api/games/{{gameId}}/horn/trigger"
          }
        }
      ]
    }
  ]
}
