# API base URL (no trailing slash). Local Vite dev default is http://localhost:3000/api when unset in code.
# VITE_API_URL=http://localhost:3000/api
# VITE_SOCKET_URL=http://localhost:3000
#
# Docker (nginx same-origin on :8080) — set via compose build args; defaults to /api and empty socket URL.
# VITE_API_URL=/api
# VITE_SOCKET_URL=
